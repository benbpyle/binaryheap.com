---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
---

<Layout title="Projects | binaryheap">
  <Header />
  <main id="main-content" class="app-layout">
    <section class="py-8 sm:py-10">
      <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">
        Projects
      </h1>
      <p class="mt-2 text-base text-foreground/80 italic">
        Things I've built and shipped.
      </p>
    </section>
    <ul class="grid gap-6 sm:grid-cols-1">
      <li
        class="rounded-md border border-border p-6 transition-colors hover:bg-foreground/5"
      >
        <h2 class="text-xl font-semibold">
          <a
            href="https://homeschoolace.com"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent"
          >
            Homeschool Ace
          </a>
        </h2>
        <p class="mt-2 text-foreground/80">
          An all-in-one platform for homeschool families — gradebook, lesson
          planner, transcript generator, attendance tracking, chores, reading
          logs, and a student portal. One account, unlimited students. Built on
          Go, Vue, React Native, and AWS. See the
          <a
            href="https://homeschoolace.com/features/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent underline decoration-dashed underline-offset-4 hover:text-accent/80"
          >full feature list</a>,
          <a
            href="https://homeschoolace.com/pricing/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent underline decoration-dashed underline-offset-4 hover:text-accent/80"
          >pricing</a>, the
          <a
            href="https://homeschoolace.com/blog/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent underline decoration-dashed underline-offset-4 hover:text-accent/80"
          >blog</a>, or read
          <a
            href="https://homeschoolace.com/blog/from-spreadsheets-to-software"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent underline decoration-dashed underline-offset-4 hover:text-accent/80"
          >From Spreadsheets to Software</a>
          on why we built it.
        </p>
      </li>
      <li
        class="rounded-md border border-border p-6 transition-colors hover:bg-foreground/5"
      >
        <h2 class="text-xl font-semibold">
          <a
            href="https://github.com/pylecloudtech/mirth-operator"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-accent"
          >
            mirth-operator
          </a>
        </h2>
        <p class="mt-2 text-foreground/80">
          A Kubernetes operator for
          <a
            href="https://www.nextgen.com/products-and-services/integration-engine"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent underline decoration-dashed underline-offset-4 hover:text-accent/80"
          >Mirth Connect</a>
          that reconciles real runtime state into Prometheus metrics, ships a
          Grafana dashboard with the Helm chart, and surfaces channel-level
          health that Mirth's UI hides. Open source under
          <a
            href="https://github.com/pylecloudtech"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent underline decoration-dashed underline-offset-4 hover:text-accent/80"
          >Pyle Cloud Technologies</a>.
        </p>
      </li>
      <li
        class="rounded-md border border-border p-6 transition-colors hover:bg-foreground/5"
      >
        <h2 class="text-xl font-semibold">
          <a
            href="https://binaryheap.com"
            class="hover:text-accent"
          >
            binaryheap.com
          </a>
        </h2>
        <p class="mt-2 text-foreground/80">
          This site — a software engineering blog built with Astro, deployed on
          AWS CloudFront + S3. Hosts 120+ posts on serverless, Rust, Go, AWS
          CDK, and cloud architecture.
        </p>
      </li>
    </ul>
    <section class="mt-10 border-t border-border pt-8 pb-8">
      <p class="text-foreground/80">
        Most of my work is open source. Check out my full profile on
        <a
          href="https://github.com/benbpyle"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium text-accent underline decoration-dashed underline-offset-4 hover:text-accent/80"
        >
          GitHub
        </a>.
      </p>
    </section>
  </main>
  <Footer />
</Layout>
